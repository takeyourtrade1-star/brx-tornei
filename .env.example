# URL del microservizio di autenticazione AWS (lo stesso di new_frontend_brx)
NEXT_PUBLIC_AUTH_API_URL=

# Dominio dei cookie di sessione condivisi (SOLO in produzione: .ebartex.com)
# In locale lasciare vuoto: i cookie host-only su localhost sono condivisi tra porte.
AUTH_COOKIE_DOMAIN=

# URL pubblico di QUESTO sito (canonical, metadata, redirect assoluti)
NEXT_PUBLIC_SITE_URL=https://tournaments.ebartex.com

# Sito principale (link registrazione, ritorno alla home Ebartex)
NEXT_PUBLIC_MAIN_SITE_URL=https://www.ebartex.com

# CDN asset condivisi (CloudFront). In dev usa il fallback hardcoded in lib/config.ts
NEXT_PUBLIC_CDN_URL=
