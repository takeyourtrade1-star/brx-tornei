# URL del microservizio di autenticazione AWS (lo stesso di new_frontend_brx)
NEXT_PUBLIC_AUTH_API_URL=

# Dominio dei cookie di sessione condivisi (SOLO in produzione: .ebartex.com)
# In locale lasciare vuoto: i cookie host-only su localhost sono condivisi tra porte.
AUTH_COOKIE_DOMAIN=

# URL pubblico di QUESTO sito (canonical, metadata, redirect assoluti)
NEXT_PUBLIC_SITE_URL=https://tournaments.ebartex.com

# Sito principale (link registrazione, ritorno alla home Ebartex)
NEXT_PUBLIC_MAIN_SITE_URL=https://www.ebartex.com

# CDN asset condivisi (CloudFront). In dev usa il fallback hardcoded in lib/config.ts
NEXT_PUBLIC_CDN_URL=

# BRX Sync API — inventario utente (lo stesso di new_frontend_brx)
NEXT_PUBLIC_SYNC_API_URL=

# Meilisearch — catalogo carte (server-only, la API key non deve finire nel bundle client)
MEILISEARCH_URL=
MEILISEARCH_API_KEY=
MEILISEARCH_INDEX=cards

# WebRTC — link webcam telefono↔PC (NEXT_PUBLIC_* perché servono nel browser)
# STUN basta sulla stessa LAN; TURN necessario su reti diverse (4G/CGNAT).
NEXT_PUBLIC_WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
NEXT_PUBLIC_WEBRTC_TURN_URLS=
NEXT_PUBLIC_WEBRTC_TURN_USERNAME=
NEXT_PUBLIC_WEBRTC_TURN_CREDENTIAL=

# Signaling webcam condiviso tra istanze Lambda/Amplify (server-only, opzionale in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
